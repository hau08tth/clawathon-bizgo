# ── LLM ──────────────────────────────────────────────────────────────────────
# VNG Cloud AgentBase (nội bộ Zalopay)
LLM_API_KEY=your_llm_api_key_here
OPENAI_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
OPENAI_MODEL=qwen/qwen3.7-plus

# Hoặc dùng OpenAI thường (thay 3 dòng trên):
# LLM_API_KEY=sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ── Database (docker-compose tự override, không cần sửa) ─────────────────────
DATABASE_URL=postgresql+asyncpg://bizgro:bizgro_secret@postgres:5432/bizgro

# ── Redis (docker-compose tự override, không cần sửa) ────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=BizGro
APP_VERSION=1.0.0
DEBUG=false

# ── Microsoft Teams ───────────────────────────────────────────────────────────
# Outgoing Webhook secret (Teams → BizGro): lấy từ Teams khi tạo Outgoing Webhook
TEAMS_WEBHOOK_SECRET=

# Incoming Webhook URL (BizGro → Teams channel): lấy từ Teams channel > Connectors > Incoming Webhook
TEAMS_INCOMING_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...
